  "keyFeatures": [
    "Centralized AI provider configuration for Obsidian plugins",
    "Support for 20+ AI providers including OpenAI, Anthropic, Ollama, and Google Gemini",
    "Text generation and completion with streaming support",
    "Embeddings generation with automatic caching",
    "RAG (Retrieval-Augmented Generation) semantic search",
    "TypeScript SDK for plugin developers",
    "Multi-language support (11 languages)",
    "Provider migration and compatibility checking"
  ],
  "publicApiSurface": [
    "initAI(app, plugin, onDone, options?)",
    "waitForAI()",
    "aiProviders.execute(params)",
    "aiProviders.embed(params)",
    "aiProviders.retrieve(params)",
    "aiProviders.fetchModels(params)",
    "aiProviders.migrateProvider(provider)",
    "aiProviders.checkCompatibility(requiredVersion)",
